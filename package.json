{
  "name": "eslint-config-dherault-typescript",
  "version": "2.4.0",
  "description": "A modern TypeScript Eslint config",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dherault/eslint-config-dherault-typescript.git"
  },
  "keywords": [
    "eslint",
    "config",
    "dherault",
    "typescript"
  ],
  "author": "David Hérault <dherault@gmail.com> (https://github.com/dherault)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/dherault/eslint-config-dherault-typescript/issues"
  },
  "homepage": "https://github.com/dherault/eslint-config-dherault-typescript#readme",
  "dependencies": {
    "@eslint/js": "^9.39.4",
    "@stylistic/eslint-plugin": "^5.10.0",
    "eslint-plugin-format-react-hook-dependencies": "^3.0.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-tailwindcss-order": "^2.1.2",
    "eslint-plugin-type-imports": "^1.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "typescript-eslint": "^8.59.2"
  },
  "peerDependencies": {
    "eslint": "^9.39.4"
  },
  "overrides": {
    "eslint-plugin-tailwindcss-order": {
      "eslint": "$eslint"
    },
    "eslint-plugin-type-imports": {
      "eslint": "$eslint"
    },
    "eslint-plugin-format-react-hook-dependencies": {
      "eslint": "$eslint"
    }
  },
  "devDependencies": {
    "jiti": "^2.6.1",
    "typescript": "^6.0.3"
  }
}
